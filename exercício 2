using System;

namespace JogoPacman
{
    public class Fantasma
    {
        public string Nick;
        public string Cor;
        public string Habilidade;

        public void GerarFantasma()
        {
            Console.WriteLine($"--- Status do Fantasma ---");
            Console.WriteLine($"Nick: {Nick}");
            Console.WriteLine($"Cor: {Cor}");
            Console.WriteLine($"Habilidade: {Habilidade}");
            Console.WriteLine("--------------------------");
        }

        public void Mover(string direcao)
        {
            Console.WriteLine($"{Nick} se moveu para {direcao}");
        }
    }

    public class Program
    {
        public static void Main(string[] args)
        {
            Fantasma f1 = new Fantasma();
            f1.Nick = "Blinky";
            f1.Cor = "Vermelho";
            f1.Habilidade = "Velocidade Aumentada";

            f1.GerarFantasma();
            f1.Mover("Esquerda");
            f1.Mover("Cima");

            Console.ReadKey();
        }
    }
}
